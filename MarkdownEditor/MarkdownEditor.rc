    CONTROL         "",IDC_TAB_SIDEBAR,"SysTabControl32",WS_TABSTOP,10,52,140,270
    CONTROL         "",IDC_TREE_SIDEBAR,"SysTreeView32",TVS_HASBUTTONS | TVS_HASLINES | TVS_LINESATROOT | WS_TABSTOP,10,76,140,246
    EDITTEXT        IDC_EDIT_FILE_SEARCH,10,52,140,14,ES_AUTOHSCROLL
    CONTROL         "",IDC_EDIT_CONTENT,"RICHEDIT50W",ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL,160,52,310,270
    LTEXT           "",IDC_STATIC_OVERLAY,160,52,310,270,SS_CENTER | SS_CENTERIMAGE
    LTEXT           "No file opened | Mode: Markdown",IDC_STATIC_STATUS,7,328,466,14
    CONTROL         "",IDC_PROGRESS_STATUS,"msctls_progress32",WS_BORDER,330,328,100,14
    LTEXT           "",IDC_STATIC_PROGRESS_TEXT,434,328,38,14,SS_RIGHT
END


