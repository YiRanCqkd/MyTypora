IDD_MARKDOWNEDITOR_DIALOG DIALOGEX 0, 0, 480, 350
STYLE DS_SETFONT | DS_FIXEDSYS | WS_OVERLAPPEDWINDOW | WS_VISIBLE
EXSTYLE WS_EX_APPWINDOW
CAPTION "MyTypora - Markdown Editor"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    PUSHBUTTON      "Open File",IDC_BUTTON_OPEN,10,10,80,32,BS_FLAT | BS_OWNERDRAW
